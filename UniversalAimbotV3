-- ==================== LIMPEZA DE RASTROS ====================
local function limparRastros()
	-- Remove funções globais que poderiam indicar script
	if getgenv().AIMBOT_ATIVO then
		getgenv().AIMBOT_ATIVO = nil
	end
	
	-- Limpa variáveis de ambiente
	for k, v in pairs(getgenv()) do
		if type(v) == "function" or type(v) == "table" then
			if k:find("AIMBOT") or k:find("ESP") or k:find("SCRIPT") then
				pcall(function()
					getgenv()[k] = nil
				end)
			end
		end
	end
end

-- ==================== DETECTOR DE OBSERVADORES ====================
local function detectarObservador()
	-- Verifica se há câmera focando no player (Dev/Admin observando)
	local playerChar = Players.LocalPlayer.Character
	if not playerChar then return false end
	
	-- Lista de possíveis nomes de admin/dev que observam
	local noMesSuspeitos = {
		"Admin", "Moderator", "Developer", "Owner", "Staff",
		"Observer", "Spectator", "Camera", "Cam", "Observador"
	}
	
	-- Verifica todos os players em espectador (mortos)
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= Players.LocalPlayer then
			local char = player.Character
			-- Se um player não tem character, pode estar em espectador
			if not char then
				-- Verifica se é um dos nomes suspeitos
				for _, suspeito in ipairs(noMesSuspeitos) do
					if player.Name:find(suspeito) or player.Name:find(player.Name:upper()) then
						return true, player.Name
					end
				end
			end
		end
	end
	
	-- Verifica distância anormal de câmera
	local cameraPos = Cam.CFrame.Position
	local playerPos = playerChar:FindFirstChild("Head")
	if playerPos then
		local dist = (cameraPos - playerPos.Position).Magnitude
		-- Se câmera tá muito perto e não é primeira pessoa, pode ser observador
		if dist < 5 and dist > 0.1 then
			return true, "Unknown Observer"
		end
	end
	
	return false
end

-- ==================== AUTO-PAUSE AIMBOT ====================
local function verificarObservadorEPausar()
	if not ANTI_OBSERVADOR_ATIVO then return end
	
	local detectado, nome = detectarObservador()
	
	if detectado and AIMBOT_ATIVO then
		observador_detectado = true
		AIMBOT_ATIVO = false
		print("⚠️ OBSERVADOR DETECTADO: " .. (nome or "Unknown"))
		print("🔒 Aimbot pausado automaticamente!")
		
		Rayfield:Notify({
			Title = "⚠️ OBSERVADOR DETECTADO!",
			Content = "Aimbot pausado. Observador: " .. (nome or "Unknown"),
			Duration = 3,
			Image = 4483362458,
		})
	elseif not detectado and observador_detectado then
		observador_detectado = false
		print("✅ Observador desapareceu. Aimbot pode ser ativado novamente.")
	end
end

-- ==================== AIMBOT ====================
local function getClosestPlayerInFOV()
	local nearest = nil
	local last = math.huge
	local center = Cam.ViewportSize / 2

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= Players.LocalPlayer then
			local char = player.Character
			if not char then continue end
			
			if getgenv().TEAM_CHECK and Players.LocalPlayer.Team == player.Team then
				continue
			end

			local part = char:FindFirstChild("Head")
			if part then
				local pos, visible = Cam:WorldToViewportPoint(part.Position)
				local dist = (Vector2.new(pos.x, pos.y) - center).Magnitude

				if dist < last and visible and dist < getgenv().AIM_FOV then
					last = dist
					nearest = player
				end
			end
		end
	end

	return nearest
end

local function aimAt(target)
	if not target or not target.Character or not target.Character:FindFirstChild("Head") then return end
	
	local cf = CFrame.new(Cam.CFrame.Position, target.Character.Head.Position)
	Cam.CFrame = Cam.CFrame:Lerp(cf, getgenv().AIM_SMOOTH)
end

-- ==================== ESP ====================
local function createESP(player)
	if player == Players.LocalPlayer then return end
	if not player.Character then return end
	if esp_cache[player] then return end

	local hl = Instance.new("Highlight")
	hl.FillColor = Color3.fromRGB(255, 0, 255)
	hl.OutlineColor = Color3.fromRGB(255, 0, 255)
	hl.FillTransparency = 0.6
	hl.Parent = player.Character

	esp_cache[player] = hl
end

local function removeESP(player)
	if esp_cache[player] then
		pcall(function()
			esp_cache[player]:Destroy()
		end)
		esp_cache[player] = nil
	end
end

-- ==================== FULLBRIGHT ====================
local function enableFullbright()
	if not getgenv().ORIGINAL_BRIGHTNESS then
		getgenv().ORIGINAL_BRIGHTNESS = Lighting.Brightness
		getgenv().ORIGINAL_CLOCK_TIME = Lighting.ClockTime
		getgenv().ORIGINAL_FOG_END = Lighting.FogEnd
	end
	
	Lighting.Brightness = 2
	Lighting.ClockTime = 14
	Lighting.FogEnd = 100000
end

local function disableFullbright()
	if getgenv().ORIGINAL_BRIGHTNESS then
		Lighting.Brightness = getgenv().ORIGINAL_BRIGHTNESS
		Lighting.ClockTime = getgenv().ORIGINAL_CLOCK_TIME
		Lighting.FogEnd = getgenv().ORIGINAL_FOG_END
	end
end

-- ==================== INFINITE JUMP ====================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.Space and INFINITE_JUMP then
		local char = Players.LocalPlayer.Character
		if char and char:FindFirstChild("Humanoid") then
			char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		end
	end
end)

-- ==================== PLAYER EVENTS ====================
Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		if ESP_ATIVO then
			createESP(player)
		end
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	removeESP(player)
	if getgenv().LOCKED_TARGET == player then
		getgenv().LOCKED_TARGET = nil
	end
end)

for _, player in ipairs(Players:GetPlayers()) do
	if player ~= Players.LocalPlayer then
		player.CharacterAdded:Connect(function()
			task.wait(0.5)
			if ESP_ATIVO then
				createESP(player)
			end
		end)
	end
end

-- ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function()

	-- VERIFICAR OBSERVADOR A CADA FRAME
	verificarObservadorEPausar()

	-- AIMBOT
	if AIMBOT_ATIVO then
		local target = nil
		
		if TARGET_LOCK and getgenv().LOCKED_TARGET and getgenv().LOCKED_TARGET.Character then
			target = getgenv().LOCKED_TARGET
		else
			target = getClosestPlayerInFOV()
		end
		
		if target and target.Character and target.Character:FindFirstChild("Head") then
			aimAt(target)
		end
	end

	-- ESP
	if ESP_ATIVO then
		for _, player in ipairs(Players:GetPlayers()) do
			if player.Character then
				createESP(player)
			end
		end
	else
		for player in pairs(esp_cache) do
			removeESP(player)
		end
	end

	-- NOCLIP (otimizado - roda a cada 0.1s)
	if NOCLIP then
		local currentTime = tick()
		if currentTime - last_noclip_time >= 0.1 then
			last_noclip_time = currentTime
			local char = Players.LocalPlayer.Character
			if char then
				for _, v in pairs(char:GetDescendants()) do
					if v:IsA("BasePart") then
						v.CanCollide = false
					end
				end
			end
		end
	end

end)

