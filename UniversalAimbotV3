-- ==================== INFINITE JUMP ====================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.Space and INFINITE_JUMP then
		local char = Players.LocalPlayer.Character
		if char and char:FindFirstChild("Humanoid") then
			char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		end
	end
end)

-- ==================== MOUSE SENSITIVITY ====================
local mouse = Players.LocalPlayer:GetMouse()
local lastMousePos = mouse.UnitRay.Direction
local cameraOffsetX = 0
local cameraOffsetY = 0

-- ==================== PLAYER LIST UPDATE ====================
local function updatePlayerList()
	local players = {}
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= Players.LocalPlayer then
			table.insert(players, player.Name)
		end
	end
	return players
end

-- ==================== PLAYER EVENTS ====================
Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		if ESP_ATIVO then
			createESP(player)
		end
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	removeESP(player)
	if getgenv().LOCKED_TARGET == player then
		getgenv().LOCKED_TARGET = nil
	end
end)

for _, player in ipairs(Players:GetPlayers()) do
	if player ~= Players.LocalPlayer then
		player.CharacterAdded:Connect(function()
			task.wait(0.5)
			if ESP_ATIVO then
				createESP(player)
			end
		end)
	end
end

-- ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function()

	-- AIMBOT
	if AIMBOT_ATIVO then
		local target = nil
		
		if TARGET_LOCK and getgenv().LOCKED_TARGET and getgenv().LOCKED_TARGET.Character then
			target = getgenv().LOCKED_TARGET
		else
			target = getClosestPlayerInFOV()
		end
		
		if target and target.Character and target.Character:FindFirstChild("Head") then
			aimAt(target)
		end
	end

	-- ESP
	if ESP_ATIVO then
		for _, player in ipairs(Players:GetPlayers()) do
			if player.Character then
				createESP(player)
			end
		end
	else
		for player in pairs(esp_cache) do
			removeESP(player)
		end
	end

	-- NOCLIP
	if NOCLIP then
		local char = Players.LocalPlayer.Character
		if char then
			for _, v in pairs(char:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end
		end
	end

	-- FOV CIRCLE
	updateFOVCircle()

	-- MOUSE SENSITIVITY
	if getgenv().MOUSE_SENSITIVITY > 1 and not AIMBOT_ATIVO then
		local currentMousePos = mouse.UnitRay.Direction
		local mouseDelta = currentMousePos - lastMousePos
		
		cameraOffsetX = cameraOffsetX + mouseDelta.X * (getgenv().MOUSE_SENSITIVITY - 1) * 0.05
		cameraOffsetY = cameraOffsetY + mouseDelta.Y * (getgenv().MOUSE_SENSITIVITY - 1) * 0.05
		
		cameraOffsetX = math.clamp(cameraOffsetX, -0.5, 0.5)
		cameraOffsetY = math.clamp(cameraOffsetY, -0.5, 0.5)
		
		Cam.CFrame = Cam.CFrame * CFrame.new(cameraOffsetX * 0.01, cameraOffsetY * 0.01, 0)
		
		lastMousePos = currentMousePos
	else
		cameraOffsetX = 0
		cameraOffsetY = 0
	end

end)

