-- ==================== CACHE ====================
local esp_cache = {}
local last_noclip_time = 0
local last_observer_check = 0

-- ✅ SISTEMA ANTI-BAN (SÓ DETECTA O QUE IMPORTA)
local antibanData = {
	-- Admin: única coisa realmente detectável
	adminDetectCount = 0,
	lastAdminCheck = 0,
	
	isEscaping = false,
}

-- ==================== MONITOR SIMPLES E EFETIVO ====================

local function monitorarAnomalias()
	task.spawn(function()
		while ANTI_BAN_ATIVO and not antibanData.isEscaping do
			task.wait(2) -- Verifica a cada 2 segundos
			
			-- ÚNICA COISA QUE IMPORTA: Admin online observando
			local adminOnline = 0
			for _, player in ipairs(Players:GetPlayers()) do
				if player ~= Players.LocalPlayer and not player.Character then
					if player.Name:find("Admin") or player.Name:find("Developer") or 
					   player.Name:find("Owner") or player.Name:find("Moderator") or
					   player.UserId == 1 then
						adminOnline = adminOnline + 1
					end
				end
			end
			
			-- Se admin online e aimbot ativo = AMEAÇA REAL
			if adminOnline > 0 and AIMBOT_ATIVO then
				antibanData.adminDetectCount = antibanData.adminDetectCount + 1
				print("⚠️ ADMIN DETECTADO: " .. adminOnline .. " | Count: " .. antibanData.adminDetectCount)
				
				-- Se admin tá lá por 2+ checks = reagir
				if antibanData.adminDetectCount >= 2 then
					antibanData.isEscaping = true
					print("🚨 ADMIN OBSERVANDO! Server hop!")
					
					limparRapido()
					task.wait(0.3)
					serverHopRapido()
					
					-- Reset
					antibanData.adminDetectCount = 0
					task.wait(15)
					antibanData.isEscaping = false
				end
			else
				antibanData.adminDetectCount = 0
			end
		end
	end)
end

-- ==================== ESCAPE INSTANTÂNEO ====================

local function limparRapido()
	task.spawn(function()
		AIMBOT_ATIVO = false
		ESP_ATIVO = false
		NOCLIP = false
		INFINITE_JUMP = false
		FULLBRIGHT_ATIVO = false
	end)
	
	task.spawn(function()
		for player in pairs(esp_cache) do
			if esp_cache[player] then
				pcall(function() esp_cache[player]:Destroy() end)
			end
			esp_cache[player] = nil
		end
	end)
	
	task.spawn(function()
		if getgenv().ORIGINAL_BRIGHTNESS then
			Lighting.Brightness = getgenv().ORIGINAL_BRIGHTNESS
			Lighting.ClockTime = getgenv().ORIGINAL_CLOCK_TIME
			Lighting.FogEnd = getgenv().ORIGINAL_FOG_END
		end
	end)
	
	task.spawn(function()
		pcall(function()
			getgenv().AIMBOT_ATIVO = nil
			getgenv().ESP_ATIVO = nil
			getgenv().AIM_FOV = nil
			getgenv().AIM_SMOOTH = nil
		end)
	end)
end

local function serverHopRapido()
	print("⚡ SERVER HOP!")
	task.wait(0.3)
	
	local teleportService = game:GetService("TeleportService")
	pcall(function()
		teleportService:Teleport(game.PlaceId, Players.LocalPlayer)
	end)
end

-- ==================== RESTO DO CÓDIGO ====================

local function limparRastros()
	pcall(function()
		getgenv().AIMBOT_ATIVO = nil
		getgenv().ESP_ATIVO = nil
		getgenv().AIM_FOV = nil
		getgenv().AIM_SMOOTH = nil
	end)
	print("✅ Rastros limpos")
end

local function detectarObservador()
	local currentTime = tick()
	if currentTime - last_observer_check < 2 then return false end
	last_observer_check = currentTime
	
	local nomesAdmin = {"Admin", "Developer", "Owner", "Moderator"}
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= Players.LocalPlayer and not player.Character then
			for _, nome in ipairs(nomesAdmin) do
				if player.Name:find(nome) then return true end
			end
		end
	end
	return false
end

local function getClosestPlayerInFOV()
	local nearest = nil
	local last = math.huge
	local center = Cam.ViewportSize / 2

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= Players.LocalPlayer then
			local char = player.Character
			if not char then continue end
			
			if getgenv().TEAM_CHECK and Players.LocalPlayer.Team == player.Team then
				continue
			end

			local part = char:FindFirstChild("Head")
			if part then
				local pos, visible = Cam:WorldToViewportPoint(part.Position)
				local dist = (Vector2.new(pos.x, pos.y) - center).Magnitude

				if dist < last and visible and dist < getgenv().AIM_FOV then
					last = dist
					nearest = player
				end
			end
		end
	end

	return nearest
end

local function aimAt(target)
	if not target or not target.Character or not target.Character:FindFirstChild("Head") then return end
	local cf = CFrame.new(Cam.CFrame.Position, target.Character.Head.Position)
	Cam.CFrame = Cam.CFrame:Lerp(cf, getgenv().AIM_SMOOTH)
end

local function createESP(player)
	if player == Players.LocalPlayer then return end
	if not player.Character then return end
	if esp_cache[player] then return end

	local hl = Instance.new("Highlight")
	hl.FillColor = Color3.fromRGB(255, 0, 255)
	hl.OutlineColor = Color3.fromRGB(255, 0, 255)
	hl.FillTransparency = 0.6
	hl.Parent = player.Character

	esp_cache[player] = hl
end

local function removeESP(player)
	if esp_cache[player] then
		pcall(function() esp_cache[player]:Destroy() end)
		esp_cache[player] = nil
	end
end

local function enableFullbright()
	if not getgenv().ORIGINAL_BRIGHTNESS then
		getgenv().ORIGINAL_BRIGHTNESS = Lighting.Brightness
		getgenv().ORIGINAL_CLOCK_TIME = Lighting.ClockTime
		getgenv().ORIGINAL_FOG_END = Lighting.FogEnd
	end
	Lighting.Brightness = 2
	Lighting.ClockTime = 14
	Lighting.FogEnd = 100000
end

local function disableFullbright()
	if getgenv().ORIGINAL_BRIGHTNESS then
		Lighting.Brightness = getgenv().ORIGINAL_BRIGHTNESS
		Lighting.ClockTime = getgenv().ORIGINAL_CLOCK_TIME
		Lighting.FogEnd = getgenv().ORIGINAL_FOG_END
	end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.Space and INFINITE_JUMP then
		local char = Players.LocalPlayer.Character
		if char and char:FindFirstChild("Humanoid") then
			char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		end
	end
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		if ESP_ATIVO then createESP(player) end
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	removeESP(player)
	if getgenv().LOCKED_TARGET == player then getgenv().LOCKED_TARGET = nil end
end)

for _, player in ipairs(Players:GetPlayers()) do
	if player ~= Players.LocalPlayer then
		player.CharacterAdded:Connect(function()
			task.wait(0.5)
			if ESP_ATIVO then createESP(player) end
		end)
	end
end

RunService.RenderStepped:Connect(function()
	if AIMBOT_ATIVO then
		if detectarObservador() then AIMBOT_ATIVO = false print("⚠️ Admin detectado") return end
		
		local target = nil
		if TARGET_LOCK and getgenv().LOCKED_TARGET and getgenv().LOCKED_TARGET.Character then
			target = getgenv().LOCKED_TARGET
		else
			target = getClosestPlayerInFOV()
		end
		
		if target and target.Character and target.Character:FindFirstChild("Head") then
			aimAt(target)
		end
	end

	if ESP_ATIVO then
		for _, player in ipairs(Players:GetPlayers()) do
			if player.Character then createESP(player) end
		end
	else
		for player in pairs(esp_cache) do removeESP(player) end
	end

	if NOCLIP then
		local currentTime = tick()
		if currentTime - last_noclip_time >= 0.1 then
			last_noclip_time = currentTime
			local char = Players.LocalPlayer.Character
			if char then
				for _, v in pairs(char:GetDescendants()) do
					if v:IsA("BasePart") then v.CanCollide = false end
				end
			end
		end
	end
end)

